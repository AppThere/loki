# Error messages shown to the user.

# Document load errors
error-load-not-found = File not found: { $path }
error-load-invalid-format = This file could not be opened. It may be damaged or in an unsupported format.
error-load-permission = Permission denied: { $path }
error-load-unknown = An error occurred while opening the document.

# File picker
error-picker-not-supported = File picker is not yet supported on this device.

# Navigation
error-go-back = Go back

# File picker
error-file-picker = Could not open file picker: { $err }
